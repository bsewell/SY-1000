/* =========================================================
   DESIGN TOKENS (Boss TONE STUDIO reference, extracted 2026)
   bg-base:        #1A1C1F
   bg-surface:     #252B32
   accent:         #33D6FF
   text-primary:   #FFFFFF
   text-secondary: rgba(255,255,255,0.80)  -> approx rgb(204,204,204)
   text-muted:     rgba(255,255,255,0.64)  -> approx rgb(163,163,163)
   text-disabled:  rgba(255,255,255,0.32)  -> approx rgb(82,82,82)
   border-hairline: rgba(255,255,255,0.32)  -> approx rgb(82,82,82)
   hover-fill:     rgba(255,255,255,0.10)  -> approx rgb(26,26,26) over base
   scrollbar-thumb: rgba(255,255,255,0.50) -> approx rgb(128,128,128)
   ========================================================= */


/* CUSTOM QTREEWIDGET STYLE */
bankTreeList#banklist {
    background-color: #1A1C1F;
}
QTreeWidget#banklist {
    font-family: Arial;
    font-weight: Normal;
    color: #FFFFFF;
    background-color: #1A1C1F;
    selection-color: #FFFFFF;
    selection-background-color: rgb(20, 50, 65);
    border-style: solid;
    border-width: 1px;
    border-radius: 3px;
    border-color: rgb(82, 82, 82);
}
QTreeWidget#banklist QHeaderView::section:only-one {
    font-family: Arial;
    font-weight: Normal;
    border-style: solid;
    border-width: 1px;
    border-radius: 3px;
    border-color: rgb(82, 82, 82);
    background-color: #252B32;
    color: #FFFFFF;
}
QTreeWidget#banklist::branch {
    margin: 10px;
    width: 9px;
}
QTreeWidget#banklist::branch:has-children:closed {
    image: url(":/images/expand.png") 0 0 0 0 stretch stretch;
}
QTreeWidget#banklist::branch:has-children:open {
    image: url(":/images/collapse.png") 0 0 0 0 stretch stretch;
}
QTreeWidget#banklist QScrollBar:vertical {
    border: none;
    background: #1A1C1F;
    width: 8px;
    margin: 0px;
}
QTreeWidget#banklist QScrollBar::handle:vertical {
    border-style: none;
    border-radius: 4px;
    background: rgba(255, 255, 255, 128);
    min-height: 24px;
}
QTreeWidget#banklist QScrollBar::handle:vertical:hover {
    background: rgba(255, 255, 255, 180);
}
QTreeWidget#banklist QScrollBar::add-line:vertical,
QTreeWidget#banklist QScrollBar::sub-line:vertical {
    height: 0px;
    background: none;
}
QTreeWidget#banklist QScrollBar::add-page:vertical,
QTreeWidget#banklist QScrollBar::sub-page:vertical {
    background: none;
}


/* CUSTOM QCOMBOBOX STYLE */

QComboBox#smallcombo {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
    background-color: #1A1C1F;
    selection-background-color: rgb(20, 50, 65);
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
    padding: 4px 18px 4px 10px;
}
QComboBox#smallcombo:hover {
    background-color: rgb(32, 36, 42);
    border-color: rgb(120, 120, 120);
}
QComboBox#smallcombo::drop-down {
    border-style: none;
}
QComboBox#smallcombo::down-arrow {
    image: url(":/images/dropdown.png") 0 0 0 0 stretch stretch;
    image-position: center right;
}
QComboBox#smallcombo QFrame {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
    padding: 4px 18px 4px 10px;
}

/* CUSTOM SCROLLBAR STYLE */

QComboBox#smallcombo QScrollBar:vertical {
    border: none;
    background: #1A1C1F;
    width: 8px;
    margin: 0px;
}
QComboBox#smallcombo QScrollBar::handle:vertical {
    border-style: none;
    border-radius: 4px;
    background: rgba(255, 255, 255, 128);
    min-height: 24px;
}
QComboBox#smallcombo QScrollBar::handle:vertical:hover {
