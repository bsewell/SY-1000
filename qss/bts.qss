/* CUSTOM GROUPBOX STYLE */

QGroupBox#groupbox::title {
subcontrol-origin: border;
subcontrol-position: top left;
position: relative;
margin-left: 2px;
margin-right: 2px;
top: -7px;
left: 5px;
}
QGroupBox#groupbox {
font-family: Arial;
font-weight: normal;
color: rgb(255,255,255);
border-width: 1px;
border-radius: 0px;
border-style: solid;
border-color:  rgb(130,130,130);
margin-top: 10px;
padding: 10px;
background-color: transparent;
}
 
