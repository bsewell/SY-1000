/* CUSTOM QTREEWIDGET STYLE */
bankTreeList#banklist{
background-color rgb(20,20,20);
}
QTreeWidget#banklist {
font-family: Arial;
font-weight: Normal;
color: rgb(185,224,243);
background-color: rgba(0,0,0,255);
selection-color: rgb(255,255,255);
selection-background-color: rgb(50,50,150);
border-style: solid;
border-width: 1px;
border-radius: 3px;
border-color: rgb(150,150,150);
}
QTreeWidget#banklist QHeaderView::section:only-one {
font-family: Arial;
font-weight: Normal;
border-style: solid;
border-width: 1px;
border-radius: 3px;
border-color: rgba(150,150,150,255);
background-color: rgb(0,0,0);
color: rgb(185,224,243);
}
QTreeWidget#banklist::branch {
margin: 10px;
width: 9px;
}
QTreeWidget#banklist::branch:has-children:closed {
image: url(":/images/expand.png") 0 0 0 0 stretch stretch;
}
QTreeWidget#banklist::branch:has-children:open {
image: url(":/images/collapse.png") 0 0 0 0 stretch stretch;
}
QTreeWidget#banklist QScrollBar:vertical {
border: none;
background: rgb(62,75,81);
width: 15px;
margin: 10px 0px 10px 0px;
}
QTreeWidget#banklist QScrollBar::handle:vertical {
border-style: solid;
border-width: 1px;
border-radius: 3px;
border-color: rgb(185,224,243);
background: rgb(185,224,243);
min-height: 40px;
max-height: 40px;
}
QTreeWidget#banklist QScrollBar::add-line:vertical {
background: rgb(62,75,81);
height: 9px;
subcontrol-position: bottom;
subcontrol-origin: margin;
}
QTreeWidget#banklist QScrollBar::sub-line:vertical {
background: rgb(62,75,81);
height: 9px;
subcontrol-position: top;
subcontrol-origin: margin;
}
QTreeWidget#banklist QScrollBar:up-arrow:vertical {
image: url(":/images/uparrow.png") 0 0 0 0 stretch stretch;
image-position: center center;
width: 20px;
height: 10px;
}
QTreeWidget#banklist QScrollBar::down-arrow:vertical {
image: url(":/images/downarrow.png") 0 0 0 0 stretch stretch;
image-position: center center;
width: 20px;
height: 10px;
}
QTreeWidget#banklist QScrollBar::add-page:vertical,
QTreeWidget#banklist QScrollBar::sub-page:vertical {
background: none;
}

/* CUSTOM QCOMBOBOX STYLE */

QComboBox#smallcombo {
font-family: Arial;
font-weight: normal;
color: rgb(185,224,243);
background-color: rgb(0,0,0);
selection-background-color: rgb(30,30,255);
border-style: solid;
border-width: 1px;
border-radius: 1px;
border-color: rgb(150,150,150);
padding: 4px 18px 4px 10px;
}
QComboBox#smallcombo::drop-down {
border-style: none;
}
QComboBox#smallcombo::down-arrow {
image: url(":/images/dropdown.png") 0 0 0 0 stretch stretch;
image-position: center right;
}
QComboBox#smallcombo QFrame {
font-family: Arial;
/*font-size: 10px;*/
font-weight: normal;
color: rgb(185,224,243);
background-color: rgb(0,0,0);
border-style: solid;
border-width: 1px;
border-radius: 1px;
border-color: rgb(150,150,150);
padding: 4px 18px 4px 10px;
}

/* CUSTOM SCROLLBAR STYLE */

QComboBox#smallcombo QScrollBar:vertical {
border: none;
background: rgb(20,20,20);
width: 9px;
margin: 10px 0px 10px 0px;
}
QComboBox#smallcombo QScrollBar::handle:vertical {
border-style: solid;
border-width: 1px;
border-radius: 1px;
border-color: rgb(185,224,243);
background: rgb(185,224,243);
min-height: 40px;
max-height: 40px;
}
QComboBox#smallcombo QScrollBar::add-line:vertical {
background: rgb(20,20,20);
height: 9px;
subcontrol-position: bottom;
subcontrol-origin: margin;
}
QComboBox#smallcombo QScrollBar::sub-line:vertical {
background: rgb(20,20,20);
height: 9px;
subcontrol-position: top;
subcontrol-origin: margin;
}
QComboBox#smallcombo QScrollBar:up-arrow:vertical {
image: url(":/images/uparrow.png") 0 0 0 0 stretch stretch;
image-position: center center;
width: 9px;
height: 10px;
}
QComboBox#smallcombo QScrollBar::down-arrow:vertical {
image: url(":/images/downarrow.png") 0 0 0 0 stretch stretch;
image-position: center center;
width: 9px;
height: 10px;
}
QComboBox#smallcombo QScrollBar::add-page:vertical,
QComboBox#smallcombo QScrollBar::sub-page:vertical {
background: none;
}

