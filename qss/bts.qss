}
QComboBox#largecombo QFrame {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
}

/* CUSTOM SCROLLBAR STYLE */

QComboBox#largecombo QScrollBar:vertical {
    border: none;
    background: #1A1C1F;
    width: 8px;
    margin: 0px;
}
QComboBox#largecombo QScrollBar::handle:vertical {
    border-style: none;
    border-radius: 4px;
    background: rgba(255, 255, 255, 128);
    min-height: 24px;
}
QComboBox#largecombo QScrollBar::handle:vertical:hover {
    background: rgba(255, 255, 255, 180);
}
QComboBox#largecombo QScrollBar::add-line:vertical,
QComboBox#largecombo QScrollBar::sub-line:vertical {
    height: 0px;
