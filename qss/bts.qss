/* TABBAR STYLE   */

QTabBar#pagecombobox {
font-family: Arial;
font-weight: normal;
color: rgb(185,224,243);
background-color: rgb(0,0,0);
border-width: 2px;
border-radius: 1px;
border-style: solid;
border-color:  rgb(120,120,120);
}

QTabBar#pagecombobox::tab:selected {
background-color: rgba(30, 30, 255, 150);
}

QTabBar#pagecombobox::tab:hover {
background-color: rgba(2, 5, 255, 50);
}

QTabBar#pagecombobox::tab {
background-color: rgba(0, 0, 0, 200);
padding: 2px;
border: 2px;
text-align: center;
/*height: 32px;
width: 100px; */
}

QSpinBox#spinbox {
font-family: Arial;
font-weight: normal;
color: rgb(185,224,243);
background-color: rgb(0,0,0);
border-width: 1px;
border-radius: 1px;
border-style: solid;
border-color:  rgb(120,120,120);
/*padding: 1px;
padding-right: 5px;*/
}
