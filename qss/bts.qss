/* CUSTOM DISPLAY STYLE */

#display {
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 2px;
    border-color: rgb(82, 82, 82);
}
QLabel#bankMain {
    font-family: Arial;
    font-weight: bold;
    color: #FFFFFF;
}
QLabel#bankSub {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
}
QLabel#nameMain {
    font-family: Arial;
    font-weight: bold;
    color: #FFFFFF;
}
QLabel#nameSub {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
}
QLabel#valueMain {
    font-family: Arial;
    font-weight: bold;
    color: #33D6FF;
}
QLabel#valueSub {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
}


/* CUSTOM LABEL STYLES */

QLabel#display {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
}
QLabel#title {
    font-family: Arial;
    font-weight: bold;
    color: #FFFFFF;
}
QLabel#selectlabel {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
}
QLabel#button {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
}
QLabel#panelButton {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
}


/* CUSTOM GROUPBOX STYLE
   Flat, borderless — content still laid out correctly,
   but no visible frame or oversized title gutter. */

QGroupBox#groupbox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    position: relative;
    top: 0px;
    left: 4px;
    padding: 0 2px;
    color: rgb(100, 120, 130);
    font-family: Arial;
    font-weight: normal;
    font-size: 10px;
}
QGroupBox#groupbox {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
    border-width: 0px;
    border-style: none;
    border-radius: 0px;
    border-color: transparent;
    margin-top: 12px;
    padding: 4px;
    background-color: transparent;
}


/* CUSTOM CONTROLLABEL STYLE */

QLabel#customlabel {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
}

QLabel#stomplabel {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
}


/* CONTROL VALUE DISPLAYS */

QLineEdit#editdisplay {
    font-family: Arial;
    font-weight: normal;
    color: #33D6FF;
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
}

QTextEdit#btsdisplay {
    font-family: Arial;
    font-weight: normal;
    color: #33D6FF;
    background-color: #1A1C1F;
    border-style: none;
}

QLineEdit#targetdisplay {
    font-family: Arial;
    font-weight: normal;
    color: #33D6FF;
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
}

QLineEdit#catalogdisplay {
    font-family: Arial;
    font-weight: normal;
    color: #FFFFFF;
    background-color: #1A1C1F;
    border-style: solid;
    border-width: 1px;
    border-radius: 2px;
    border-color: rgb(82, 82, 82);
}


/* TABBAR STYLE
   Active tab: Boss cyan underline (no fill).
   Inactive:   dim white text.
   Hover:      subtle brighten. */

QTabBar#pagecombobox {
    font-family: Arial;
    font-weight: normal;
    color: rgb(163, 163, 163);
    background-color: #1A1C1F;
    border-width: 0px;
    border-style: none;
    border-bottom: 1px solid rgb(82, 82, 82);
}

QTabBar#pagecombobox::tab {
    color: rgb(163, 163, 163);
    background-color: transparent;
    padding: 4px 10px;
    border: none;
    border-bottom: 3px solid transparent;
    margin-bottom: 0px;
    text-align: center;
}

QTabBar#pagecombobox::tab:selected {
    color: #33D6FF;
    background-color: transparent;
    border-bottom: 3px solid #33D6FF;
}

QTabBar#pagecombobox::tab:hover {
    color: #FFFFFF;
    background-color: rgba(255, 255, 255, 18);
    border-bottom: 3px solid rgba(51, 214, 255, 100);
}


/* SPINBOX */

QSpinBox#spinbox {
    font-family: Arial;
    font-weight: normal;
    color: #33D6FF;
    background-color: #1A1C1F;
    border-width: 1px;
    border-radius: 2px;
    border-style: solid;
    border-color: rgb(82, 82, 82);
}
QSpinBox#spinbox:hover {
    border-color: rgb(120, 120, 120);
}
